{
  "name": "@octen.ai/cli",
  "version": "0.2.0",
  "description": "Command-line tool for Octen — web search, extract, chat, embeddings, and one-command MCP/Skills setup.",
  "type": "module",
  "license": "MIT",
  "author": "Octen <hello@octen.ai>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Octen-Team/octen-cli.git"
  },
  "homepage": "https://github.com/Octen-Team/octen-cli#readme",
  "bugs": "https://github.com/Octen-Team/octen-cli/issues",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "octen": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "sync-skills": "tsx scripts/sync-skills.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.0.1",
    "smol-toml": "^1.7.0",
    "tar": "^7.5.16"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/tar": "^6.1.13",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
